  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "cap:sync": "npx cap sync android",
    "cap:build": "npm run build && npx cap sync android",
    "cap:open": "npx cap open android",
    "cap:release": "npm run cap:build && cd android && gradlew.bat assembleRelease",
    "cap:release:unix": "npm run cap:build && cd android && ./gradlew assembleRelease",
    "cap:install": "npm run cap:build && cd android && gradlew.bat installRelease",
    "cap:install:unix": "npm run cap:build && cd android && ./gradlew installRelease",
    "cap:clean": "cd android && gradlew.bat clean",
    "cap:live:sync": "node -e \"process.env.CAP_LIVE_URL=process.env.CAP_LIVE_URL||'http://30.28.73.56:5173';require('child_process').execSync('npx cap sync android',{stdio:'inherit',env:process.env})\"",
    "cap:live:open": "node -e \"process.env.CAP_LIVE_URL=process.env.CAP_LIVE_URL||'http://30.28.73.56:5173';require('child_process').execSync('npx cap open android',{stdio:'inherit',env:process.env})\"",
    "cap:live:run": "node -e \"process.env.CAP_LIVE_URL=process.env.CAP_LIVE_URL||'http://30.28.73.56:5173';require('child_process').execSync('npx cap run android --no-sync',{stdio:'inherit',env:process.env})\""
  },
