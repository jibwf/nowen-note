{
  "name": "nowen-note-backend",
  "version": "1.3.7",
  "scripts": {
    "dev": "tsx watch src/index.hardened.ts",
    "build": "node build.bundle.mjs",
    "build:tsc": "tsc",
    "start": "node dist/index.js",
    "test": "node --import tsx --test tests/*.test.ts",
    "test:serial": "node scripts/run-tests-serial.mjs",
    "rebuild:node": "npm rebuild better-sqlite3",
    "rebuild:electron": "node ../scripts/rebuild-native.mjs --prebuild=true",
    "migrate:inline-images": "node ../scripts/migrate-inline-images-to-attachments.mjs",
    "migrate:inline-images:apply": "node ../scripts/migrate-inline-images-to-attachments.mjs --apply"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@types/ws": "^8.18.1",
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.7.0",
    "bonjour-service": "^1.2.1",
    "busboy": "^1.6.0",
    "hono": "^4.6.15",
    "jsonwebtoken": "^9.0.3",
    "jszip": "^3.10.1",
    "lunar-javascript": "^1.7.7",
    "mammoth": "^1.11.0",
    "pg": "^8.22.0",
    "sanitize-html": "^2.17.5",
    "sharp": "^0.33.5",
    "sqlite-vec": "^0.1.9",
    "unpdf": "^1.6.2",
    "unzipper": "^0.12.3",
    "uuid": "^11.0.5",
    "word-extractor": "^1.0.4",
    "ws": "^8.20.0",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.30",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.20.0",
    "@types/sanitize-html": "^2.16.1",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
